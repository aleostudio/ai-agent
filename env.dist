# App config (127.0.0.1 for localhost, 0.0.0.0 for whole network)
APP_NAME="AI agent"
APP_HOST=0.0.0.0
APP_PORT=9201
APP_VERSION="v1"
APP_URL=http://localhost:9201

# Logging
DEBUG=False

# Provider config (host.docker.internal for Ollama on Docker)
#
# Provider | Provider base url
# ---------+------------------
# ollama   | http://localhost:11434
# openai   | https://api.openai.com/v1
# groq     | https://api.groq.com
PROVIDER="ollama"
PROVIDER_BASE_URL="http://localhost:11434"
PROVIDER_API_KEY="-"

# Model config
MODEL="llama3.1:8b"
TEMPERATURE=0.5
MAX_RETRIES=3

# Response config
# full: raw model response (sync)
# text: textual response only
# stream: streamed response (tokens)
RESPONSE_TYPE="full"

# HTTP API config
# Disable FastAPI HTTP routes (/interact, /tools, /ui, /) for pure A2A deployments
HTTP_API_ENABLED=true

# MCP servers
MCP_ENABLED=False
MCP_SERVERS='[{"name": "mcp-server", "transport": "sse", "url": "http://localhost:8000/sse"}]'
TOOL_CALL_MAX_ITERATIONS=10

# A2A config (A2A_ROLE = orchestrator | client)
A2A_ENABLED=False
A2A_ROLE=client
REGISTRY_URL=http://localhost:9300
REGISTRY_TIMEOUT_S=4.0
